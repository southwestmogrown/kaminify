# ─── Clerk ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Redirect URLs for Clerk sign-in/sign-up flows
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Server-side key for demo runs. Never exposed to the client.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL and service role key (for server-side admin operations)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Browserless ──────────────────────────────────────────────────────────────
# WebSocket URL for headless Chrome (JS-rendered site scraping)
# Get one at https://browserless.io or run your own instance
BROWSERLESS_WS_URL=wss://chrome.browserless.io

# ─── Demo limits ─────────────────────────────────────────────────────────────
DEMO_RUN_LIMIT=3
DEMO_PAGE_LIMIT=3
NEXT_PUBLIC_DEMO_RUN_LIMIT=3

# ─── API Key Encryption ───────────────────────────────────────────────────────
# 64-char hex-encoded key (32 bytes) used to encrypt user API keys at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Change this to a unique value before deploying. If you rotate it,
# existing encrypted user keys can no longer be decrypted — users must re-add them.
API_KEY_KEK=your-64-char-hex-key-here

# ─── Sentry ───────────────────────────────────────────────────────────────────
# DSN from https://sentry.io → project settings → Clients Keys
SENTRY_DSN=https://...@o...ingest.sentry.io/...
